# Copy to .env (gitignored) and fill in. Read by the collector / CI.

# Semantic Scholar API key — required for the --with-s2 scraper to return data.
# Without it, the public search-API rate-limits every venue to 0 (still tracked
# in metadb/stats.json.failures, but the rolling DB sees nothing).
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Anthropic API key — required for I-3 prompt-cached pipeline runs via SDK.
# If unset, _run_pipeline.py falls back to `claude --model sonnet -p` (Claude
# Code CLI), which still works but skips explicit cache_control.
ANTHROPIC_API_KEY=

# Google API key — required when /find-topic --model gemini-pro|gemini-flash.
# https://aistudio.google.com/apikey  (Gemini API has a free tier)
# Used by _run_pipeline.py via google-genai SDK with cached_content for the
# matched-papers prefix (mirrors the Anthropic ephemeral-cache pattern).
GOOGLE_API_KEY=

# Optional: contact email for the OpenAlex polite pool (--with-journal).
# OpenAlex returns the same data with no key, but rate-limits the anonymous
# pool more aggressively. Setting `mailto=` lifts those limits.
# https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_MAILTO=
