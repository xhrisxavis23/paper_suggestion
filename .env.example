# Copy to .env (gitignored) and fill in. Read by the collector / CI.

# Semantic Scholar API key — required for the --with-s2 scraper to return data.
# Without it, the public search-API rate-limits every venue to 0 (still tracked
# in metadb/stats.json.failures, but the rolling DB sees nothing).
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Anthropic API key — required for I-3 prompt-cached pipeline runs via SDK.
# If unset, _run_pipeline.py falls back to `claude --model sonnet -p` (Claude
# Code CLI), which still works but skips explicit cache_control.
ANTHROPIC_API_KEY=
